# Kiosko Media Center · producción final
# Copia este archivo como .env en producción o añade estas variables en Portainer.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Persistencia
DATA_DIR=/app/data
MAX_PAYLOAD_MB=25

# Logs normales de producción
# 0 = sin log HTTP completo
DEBUG_HTTP=0

# Umbral para avisar de APIs lentas
SLOW_API_LOG_MS=750

# Persistencia write-behind
# 350ms agrupa escrituras sin hacer la UI lenta.
PERSIST_DEBOUNCE_MS=350

# Trazas de diagnóstico
# Déjalo en 0 normalmente. Actívalo temporalmente para cazar problemas.
TRACE_ITEMS=0
TRACE_WS=0

# Sólo loguea payloads grandes por encima de este tamaño.
TRACE_PAYLOAD_BYTES=250000

# Plex / Tautulli
# Rellena estos valores según tu entorno si no los gestionas desde Opciones.
# PLEX_URL=http://plex:32400
# PLEX_TOKEN=
# TAUTULLI_API_KEY=

# Seguridad / red
# Si usas Cloudflare Tunnel o reverse proxy, no hace falta exponer este puerto fuera de Docker.
