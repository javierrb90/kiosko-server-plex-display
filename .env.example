# Plantilla opcional. En v4 la configuración principal vive en data/settings.json y se puede editar desde la vista Settings.
# Estas variables sólo se usan como configuración inicial o compatibilidad.
PORT=3000
DATA_DIR=/app/data
PLEX_URL=http://192.168.1.50:32400
PLEX_TOKEN=PEGA_AQUI_TU_TOKEN_REAL

# Token opcional para proteger POST /api/v1/items/upsert y POST /api/v1/events.
# Si queda vacío, la API conserva el comportamiento local sin autenticación.
BBQUEUE_API_TOKEN=
